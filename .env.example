# Copy to .env and fill in values:  cp .env.example .env

# App
NODE_ENV=development
LOG_LEVEL=INFO
APP_NAME=Workseed
# Port the app runs on
PORT=3000
# Public base URL — used for links in emails. The API is same-origin (/api).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL) — set the parts and the connection string is built for you
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=workseed
DB_SCHEMA=public
# Set "true" for managed databases that require TLS (adds sslmode=require)
DB_SSL=false
# Optional: a full URL OVERRIDES the DB_* parts above (Neon, RDS, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/workseed?schema=public

# Auth — must be >=32 chars. Generate one: openssl rand -base64 32
JWT_SECRET=

# Seed admin (optional) — used by `npm run db:seed`, defaults to admin@company.com / admin123
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=System Admin

# Email (optional) — without SMTP_USER/SMTP_PASSWORD, dev uses an Ethereal test account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@workseed.com
